# Base image and stack pins.
BASE_IMAGE=nvidia/cuda
BASE_TAG=12.8.1-cudnn-runtime-ubuntu22.04
ISAACSIM_VERSION=5.1.0
ISAACLAB_REF=v2.3.1
ISAACLAB_FRAMEWORKS=none
ROS2_APT_PACKAGE=ros-base
LEROBOT_REF=v0.4.1
OPENPI_REF=e6b044115c075dc64a2e4e23d33ea3a3c293f123
UV_VERSION=0.5.1
SMOLVLA_PYTHON_VERSION=3.11.9
OPENPI_PYTHON_VERSION=3.11.9

# Paths inside the container.
ISAACLAB_ROOT=/opt/robotics/IsaacLab
ISAACLAB_RUNTIME_ROOT=/opt/robotics/runtime/isaaclab
ISAACLAB_VENV=/opt/robotics/runtime/isaaclab/venv
LEROBOT_ROOT=/opt/robotics/lerobot
OPENPI_ROOT=/opt/robotics/openpi
SMOLVLA_VENV=/opt/venvs/smolvla
OPENPI_VENV=/opt/venvs/openpi

# Final image naming defaults.
IMAGE_NAME=evilrobots/muesli-bt-isaac-lab-vla
IMAGE_TAG=latest
