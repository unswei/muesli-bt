{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Development",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "core-only",
      "displayName": "Core Only (No Integrations)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/core-only",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "MUESLI_BT_BUILD_INTEGRATION_ROS2": "OFF",
        "MUESLI_BT_BUILD_INTEGRATION_PYBULLET": "OFF",
        "MUESLI_BT_BUILD_INTEGRATION_WEBOTS": "OFF",
        "MUESLI_BT_BUILD_PYTHON_BRIDGE": "OFF",
        "MUESLI_BT_BUILD_WEBOTS_EXAMPLES": "OFF"
      }
    },
    {
      "name": "bench-release",
      "displayName": "Benchmark Release",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/bench-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "MUESLI_BT_BUILD_BENCHMARKS": "ON",
        "MUESLI_BT_BUILD_INTEGRATION_ROS2": "OFF",
        "MUESLI_BT_BUILD_INTEGRATION_PYBULLET": "OFF",
        "MUESLI_BT_BUILD_INTEGRATION_WEBOTS": "OFF",
        "MUESLI_BT_BUILD_PYTHON_BRIDGE": "OFF",
        "MUESLI_BT_BUILD_WEBOTS_EXAMPLES": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "core-only",
      "configurePreset": "core-only"
    },
    {
      "name": "bench-release",
      "configurePreset": "bench-release"
    }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "core-only",
      "configurePreset": "core-only",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "bench-release",
      "configurePreset": "bench-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
