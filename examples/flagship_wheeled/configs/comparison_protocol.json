{
  "schema_version": "flagship.comparison_protocol.v1",
  "status": "provisional",
  "name": "v0.5_pybullet_webots_prefix320",
  "scope": {
    "backends": [
      "pybullet",
      "webots"
    ],
    "scenario": "shared wheeled flagship goal-seeking",
    "comparison_window_ticks": 320,
    "tick_hz": 20
  },
  "controller": {
    "goal_tolerance_m": 0.25,
    "collision_threshold": 0.75,
    "planner": "mcts",
    "budget_ms": 10,
    "work_max": 280,
    "max_depth": 18,
    "gamma": 0.96,
    "pw_k": 2.0,
    "pw_alpha": 0.5,
    "action_schema": "flagship.cmd.v1",
    "model_service": "flagship-goal-shared-v1"
  },
  "collection": {
    "seed": 7,
    "pybullet": {
      "mode": "bt_flagship",
      "headless": true,
      "duration_sec": 16,
      "goal_x": 7.0,
      "goal_y": 3.0
    },
    "webots": {
      "entrypoint": "lisp/flagship_entry.lisp",
      "world": "examples/webots_epuck_goal/worlds/epuck_goal_cluttered.wbt"
    }
  },
  "comparison": {
    "primary_metrics": [
      "branch_agreement",
      "goal_dist_mae",
      "shared_action_mae.linear_x",
      "shared_action_mae.angular_z"
    ],
    "secondary_metrics": [
      "full_run_final_status",
      "full_run_final_goal_dist"
    ]
  },
  "notes": "Primary evidence is the shared 320-tick prefix. Full-run terminal outcome is recorded as secondary context because the current Webots flagship runs to completion while the practical PyBullet collection path is a shorter headless prefix run."
}
